# ─── LLM Provider ───────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai            # "openai" or "local"
LLM_MODEL=gpt-4o               # gpt-4o, gpt-4-vision-preview, or local model path

# ─── Embedding Models ───────────────────────────────────────
TEXT_EMBEDDING_MODEL=BAAI/bge-m3
IMAGE_EMBEDDING_MODEL=openai/clip-vit-large-patch14
EMBEDDING_DEVICE=cpu            # "cpu" or "cuda"
EMBEDDING_BATCH_SIZE=8

# ─── FAISS Index ────────────────────────────────────────────
FAISS_INDEX_PATH=data/index/faiss.index
FAISS_METADATA_PATH=data/index/metadata.json
FAISS_NLIST=100

# ─── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Retrieval ─────────────────────────────────────────────
TOP_K_RETRIEVAL=20
RERANK_TOP_N=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Data Paths ────────────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
INDEX_DIR=data/index

# ─── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860
